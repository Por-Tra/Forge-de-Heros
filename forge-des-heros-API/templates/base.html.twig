<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {# gestion du CSS #}
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('css/style.css') }}">
        {% endblock %}
    </head>
    <body>
        <header class="navbar">
        <div class="nav-container">
            <div class="nav-left">
                <a href="{{ path('app_home') }}" class="logo">Forge des Héros</a>
            </div>

            <button class="nav-toggle" onclick="toggleMenu()">☰</button>

            <div class="nav-right" id="navMenu">
                {% if app.user %}
                    <a href="{{ path('app_home') }}">Home</a>

                    {% if is_granted('ROLE_USER') %}
                        <div class="dropdown">
                            <button>Characters ▾</button>
                            <div class="dropdown-content">
                                <a href="{{ path('app_character_index') }}">List</a>
                                <a href="{{ path('app_character_new') }}">Create</a>
                            </div>
                        </div>

                        <div class="dropdown">
                            <button>Parties ▾</button>
                            <div class="dropdown-content">
                                <a href="{{ path('app_party_index') }}">List</a>
                                <a href="{{ path('app_party_new') }}">Create</a>
                            </div>
                        </div>
                    {% endif %}

                    {% if is_granted('ROLE_ADMIN') %}
                        <div class="dropdown admin">
                            <button>Admin ▾</button>
                            <div class="dropdown-content">
                                <a href="{{ path('app_character_class_index') }}">Classes</a>
                                <a href="{{ path('app_race_index') }}">Races</a>
                                <a href="{{ path('app_skill_index') }}">Skills</a>
                                <a href="{{ path('user_list') }}">Users</a>
                            </div>
                        </div>
                    {% endif %}

                    <a href="{{ path('app_logout') }}" class="logout">Logout</a>
                {% else %}
                    <a href="{{ path('app_login') }}">Login</a>
                    <a href="{{ path('app_register') }}" class="register">Register</a>
                {% endif %}
            </div>
        </div>
    </header>

        <main>
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
