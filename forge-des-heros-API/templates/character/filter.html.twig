
<form method="get" action="{{ path('app_character_index') }}">
    {# On garde la valeur de search si elle existe déjà #}
    <input type="hidden" name="search" value="{{ app.request.query.get('search') }}">

    <select name="class">
        <option value="">All classes</option>
        {% for class in classes %}
            <option value="{{ class.id }}" {% if app.request.query.get('class') == class.id %}selected{% endif %}>
                {{ class.name }}
            </option>
        {% endfor %}
    </select>

    <select name="race">
        <option value="">All races</option>
        {% for race in races %}
            <option value="{{ race.id }}" {% if app.request.query.get('race') == race.id %}selected{% endif %}>
                {{ race.name }}
            </option>
        {% endfor %}
    </select>

    <button type="submit">Filter</button>
    <a href="{{ path('app_character_index') }}">Reset</a>
</form>