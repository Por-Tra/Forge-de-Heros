{# index.html.twig #}

{% extends 'base.html.twig' %}


{% block title %}Character index{% endblock %}
{% block body %}
    {# Barre de recherche pour chercher un personnage par son nom #}
    {% include 'character/search.html.twig' %}
    {% include 'character/filter.html.twig' %}
    
    <h1>Character index</h1>

    
    

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Level</th>
                <th>Strength</th>
                <th>Dexterity</th>
                <th>Constitution</th>
                <th>Intelligence</th>
                <th>Wisdom</th>
                <th>Charisma</th>
                <th>Class</th>
                <th>Race</th>
                <th>HealthPoints</th>
                <th>Image</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for character in characters %}
            <tr>
                <td>{{ character.id }}</td>
                <td>{{ character.name }}</td>
                <td>{{ character.level }}</td>
                <td>{{ character.strength }}</td>
                <td>{{ character.dexterity }}</td>
                <td>{{ character.constitution }}</td>
                <td>{{ character.intelligence }}</td>
                <td>{{ character.wisdom }}</td>
                <td>{{ character.charisma }}</td>
                <td>{{ character.characterClass.name }}</td>
                <td>{{ character.race.name}}</td>
                <td>{{ character.healthPoints }}</td>
                <td>
                    {% if character.image %}
                        <img src="{{ asset('uploads/avatars/' ~ character.image) }}" alt="Avatar de {{ character.name }}" width="64" height="64" style="object-fit: cover;" />
                    {% else %}
                        <span>Aucun avatar</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_character_show', {'id': character.id}) }}">Show</a>
                    <a href="{{ path('app_character_edit', {'id': character.id}) }}">Edit</a>
                    {{ include('character/_delete_form.html.twig') }}

                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="12">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_character_new') }}">Create new</a>
{% endblock %}
