{# index.html.twig #}

{% extends 'base.html.twig' %}


{% block title %}Character index{% endblock %}
{% block body %}
    {# Barre de recherche pour chercher un personnage par son nom #}
    {% include 'character/search.html.twig' %}
    {% include 'character/filter.html.twig' %}
    
    {# ========== MES PERSONNAGES ========== #}
    <section class="section-user-characters">
        <h2>My characters</h2>

        {% if userCharacters|length > 0 %}
            <table class="table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Level</th>
                        <th>Strength</th>
                        <th>Dexterity</th>
                        <th>Constitution</th>
                        <th>Intelligence</th>
                        <th>Wisdom</th>
                        <th>Charisma</th>
                        <th>Class</th>
                        <th>Race</th>
                        <th>HealthPoints</th>
                        <th>Image</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for character in userCharacters %}
                    <tr>
                        <td>{{ character.id }}</td>
                        <td>{{ character.name }}</td>
                        <td>{{ character.level }}</td>
                        <td>{{ character.strength }}</td>
                        <td>{{ character.dexterity }}</td>
                        <td>{{ character.constitution }}</td>
                        <td>{{ character.intelligence }}</td>
                        <td>{{ character.wisdom }}</td>
                        <td>{{ character.charisma }}</td>
                        <td>{{ character.characterClass.name }}</td>
                        <td>{{ character.race.name}}</td>
                        <td>{{ character.healthPoints }}</td>
                        <td>
                            {% if character.image %}
                                <img src="{{ asset('uploads/avatars/' ~ character.image) }}" alt="Avatar de {{ character.name }}" width="64" height="64" style="object-fit: cover; border-radius: 8px;" />
                            {% else %}
                                <span>Aucun avatar</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_character_show', {'id': character.id}) }}">Show</a> |
                            <a href="{{ path('app_character_edit', {'id': character.id}) }}">Edit</a> |
                            {{ include('character/_delete_form.html.twig') }}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p style="text-align: center; padding: 20px; color: #999;">
                Vous n'avez pas encore créé de personnage.
            </p>
        {% endif %}

        <div style="margin: 20px 0;">
            <a href="{{ path('app_character_new') }}" class="btn btn-primary">Create a new character</a>
        </div>
    </section>

    <hr style="margin: 40px 0; border: 1px solid #ddd;" />

    {# ========== TOUS LES PERSONNAGES ========== #}
    <section class="section-all-characters">
        <h2>All characters</h2>

        {% if allCharacters|length > 0 %}
            <table class="table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Creator</th>
                        <th>Level</th>
                        <th>Strength</th>
                        <th>Dexterity</th>
                        <th>Constitution</th>
                        <th>Intelligence</th>
                        <th>Wisdom</th>
                        <th>Charisma</th>
                        <th>Class</th>
                        <th>Race</th>
                        <th>HealthPoints</th>
                        <th>Image</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for character in allCharacters %}
                    <tr>
                        <td>{{ character.id }}</td>
                        <td>{{ character.name }}</td>
                        <td>{{ character.user.username }}</td>
                        <td>{{ character.level }}</td>
                        <td>{{ character.strength }}</td>
                        <td>{{ character.dexterity }}</td>
                        <td>{{ character.constitution }}</td>
                        <td>{{ character.intelligence }}</td>
                        <td>{{ character.wisdom }}</td>
                        <td>{{ character.charisma }}</td>
                        <td>{{ character.characterClass.name }}</td>
                        <td>{{ character.race.name}}</td>
                        <td>{{ character.healthPoints }}</td>
                        <td>
                            {% if character.image %}
                                <img src="{{ asset('uploads/avatars/' ~ character.image) }}" alt="Avatar de {{ character.name }}" width="64" height="64" style="object-fit: cover; border-radius: 8px;" />
                            {% else %}
                                <span>Aucun avatar</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('app_character_show', {'id': character.id}) }}">Show</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p style="text-align: center; padding: 20px; color: #999;">
                Aucun personnage trouvé.
            </p>
        {% endif %}
    </section>

{% endblock %}
